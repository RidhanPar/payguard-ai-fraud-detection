[flake8]
max-line-length = 100
extend-ignore =
    E203,
    W503
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    build,
    dist,
    *.egg-info,
    .ipynb_checkpoints,
    data,
    models,
    reports,
    htmlcov
per-file-ignores =
    __init__.py:F401
    app/dashboard.py:E402,E501
